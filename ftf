-- PARTICLE FUNCTIONS
local function CreateParticle()
    if not UI.ParticleContainer or State.IsDestroyed then return nil end
    local size = math.random(8, 24)
    local particle = Instance.new("Frame")
    particle.Size = UDim2.new(0, size, 0, size); particle.Position = UDim2.new(math.random() * 1.4 - 0.2, 0, 1.2, 0)
    particle.BackgroundColor3 = Colors.NeonWhite; particle.BackgroundTransparency = math.random(60, 85) / 100
    particle.BorderSizePixel = 0; particle.ZIndex = 106; particle.Parent = UI.ParticleContainer
    Instance.new("UICorner", particle).CornerRadius = UDim.new(1, 0)
    local d = {frame = particle, vx = (math.random() - 0.5) * 0.004, vy = -math.random(20, 50) / 10000, created = tick(), rotation = 0, rotationSpeed = (math.random() - 0.5) * 2, pulsePhase = math.random() * math.pi * 2, originalTransparency = particle.BackgroundTransparency, lifetime = math.random(30, 60), originalSize = size, repelForce = {x = 0, y = 0}, mass = size / 10}
    table.insert(State.Particles, d); return particle
end

local function UpdateParticles()
    if State.IsDestroyed or not UI.ParticleContainer then return end
    local sx = State.MousePosition.X / UI.ScreenGui.AbsoluteSize.X; local sy = State.MousePosition.Y / UI.ScreenGui.AbsoluteSize.Y
    for i = #State.Particles, 1, -1 do
        local p = State.Particles[i]
        if not p or not p.frame.Parent then table.remove(State.Particles, i)
        else
            local cp = p.frame.Position
            if cp.Y.Scale < -0.3 or tick() - p.created > p.lifetime then p.frame:Destroy(); table.remove(State.Particles, i)
            else
                local dist = math.sqrt((cp.X.Scale - sx)^2 + (cp.Y.Scale - sy)^2)
                local rfX, rfY = 0, 0
                if dist < 0.15 and dist > 0 then
                    local power = ((0.15 - dist) / 0.15) * 0.08 / p.mass
                    rfX = (cp.X.Scale - sx) / dist * power; rfY = (cp.Y.Scale - sy) / dist * power
                end
                p.repelForce.x = p.repelForce.x * 0.85 + rfX * 0.15; p.repelForce.y = p.repelForce.y * 0.85 + rfY * 0.15
                local nx = cp.X.Scale + p.vx + p.repelForce.x; local ny = cp.Y.Scale + p.vy + p.repelForce.y
                if nx <= -0.2 then nx = 1.2 elseif nx >= 1.2 then nx = -0.2 end
                p.rotation = p.rotation + p.rotationSpeed; p.frame.Rotation = p.rotation
                local breathe = math.sin(tick() * 2.5 + p.pulsePhase) * 0.1 + 1
                p.frame.Size = UDim2.new(0, p.originalSize * breathe, 0, p.originalSize * breathe)
                p.frame.BackgroundTransparency = math.max(0.5, math.min(0.95, p.originalTransparency + math.sin(tick() * 3 + p.pulsePhase) * 0.1))
                p.vx = p.vx * 0.995; p.vy = p.vy * 0.998
                p.frame.Position = UDim2.new(nx, 0, ny, 0)
            end
        end
    end
end

