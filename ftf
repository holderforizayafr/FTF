local function hookGunHandler()
    local success, GunHandler = pcall(function()
        local modules = ReplicatedStorage:FindFirstChild("Modules")
        if modules then return require(modules:FindFirstChild("GunHandler")) end
        return require(ReplicatedStorage:FindFirstChild("GunHandler"))
    end)
    if success and GunHandler then
