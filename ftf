            local originalShoot = GunHandler.Shoot
            GunHandler.Shoot = function(params)
                if isCombatActive() and State.TargetPlayer then
                    local targetPos = getTargetPosition(State.TargetPlayer)
                    if targetPos then
                        params.AimPosition = targetPos.Position; params.Hit = targetPos
                        if params.VisibleCheck ~= nil then params.VisibleCheck = false end
                        if params.IgnoreWalls ~= nil then params.IgnoreWalls = true end
                    end
                end
                return originalShoot(params)
            end
        end
    end
end

-- ===== REMOTE EVENT HOOK =====
local function hookRemoteEvent()
    local function findShootRemote(folder)
        if not folder then return nil end
        for _, child in ipairs(folder:GetChildren()) do
            if child:IsA("RemoteEvent") then
                local name = child.Name:lower()
                if name:find("shoot") or name:find("gun") or name:find("fire") or name:find("weapon") then return child end
            end
            if child:IsA("Folder") then local found = findShootRemote(child); if found then return found end end
        end
        return nil
    end
    local remote = findShootRemote(ReplicatedStorage)
    if remote and remote:IsA("RemoteEvent") then
        local originalFireServer = remote.FireServer
        remote.FireServer = function(self, ...)
            local args = {...}
            if isCombatActive() and State.TargetPlayer then
                local targetPos = getTargetPosition(State.TargetPlayer)
                if targetPos then
                    for i, arg in ipairs(args) do if type(arg) == "Vector3" then args[i] = targetPos.Position; break end end
                    for i, arg in ipairs(args) do if type(arg) == "Instance" and arg:IsA("BasePart") then args[i] = targetPos; break end end
                end
            end
            return originalFireServer(self, unpack(args))
        end
    end
end

